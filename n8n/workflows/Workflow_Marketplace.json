      "name": "HTTP Request"
    },
    {
      "parameters": {
        "jsCode": "const alertas = $input.first().json.body.alertas;\n\nif (!alertas || alertas.length === 0) {\n  return [];\n}\n\n// Formatação de preço BRL\nconst formatPrice = (value) => new Intl.NumberFormat('pt-BR', {\n  style: 'currency',\n  currency: 'BRL',\n}).format(value);\n\n// Mapeia cada alerta e gera um item de retorno por alerta\nreturn alertas.map(alerta => {\n\n  // Cálculo de desconto\n  const discountPart = (alerta.old_price && alerta.old_price > alerta.price)\n    ? (() => {\n        const percent = Math.round(((alerta.old_price - alerta.price) / alerta.old_price) * 100);\n        const oldFormatted = formatPrice(alerta.old_price);\n        return `📉 ~${oldFormatted}~ ➡️ *${percent}% OFF*\\n\\n`;\n      })()\n    : '';\n\n  // Frete Grátis\n  const shippingPart = alerta.free_shipping\n    ? `🚚 *FRETE GRÁTIS*${alerta.is_full ? ' (Full)' : ''}\\n\\n`\n    : '';\n\n  // Parcelamento\n  const installmentsPart = alerta.installments\n    ? `💳 *PARCELAMENTO:* ${alerta.installments}\\n\\n`\n    : '';\n\n  // Cupom\n  const couponPart = alerta.coupon\n    ? `🎟️ *CUPOM:* ${alerta.coupon}\\n\\n`\n    : '';\n\n  // Montagem da mensagem\n  const message = `🔔 *ALERTA DE OFERTA*\n\n🛍️ *PRODUTO:*\n${alerta.product_name}\n\n💰 POR APENAS: *${formatPrice(alerta.price)}*\n\n${discountPart}${shippingPart}${installmentsPart}${couponPart}🔗 *LINK DE COMPRA:*\n${alerta.affiliate_link}\n\n---\n_Ofertas podem sofrer alteração de preço ou estoque a qualquer momento._\n_Para cancelar notificações: mande um *Oi* nessa conversa e acesse a opção \"Excluir um alerta de oferta\" no menu._`;\n\n  return {\n    json: {\n      whatsapp_id: alerta.whatsapp_id,\n      formatted_message: message,\n      image_url: alerta.image_url,\n      source_group: alerta.source_group,\n      send_delay_seconds: alerta.send_delay_seconds\n    }\n  };\n});"
      },
      "id": "d6241ea6-f549-4e82-8f9e-47f6850feb7f",
      "name": "Split Array",
      "type": "n8n-nodes-base.code",
