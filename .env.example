# Worker
TRIGGER_HOST=0.0.0.0
TRIGGER_PORT=8000

# Database
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Redis
REDIS_ON=true
REDIS_HOST=redis-host
REDIS_PORT=6379
REDIS_NOTIF_TTL=43200
REDIS_BYPASS_CONTACTS=["5511999990000"]

# LLM
OPENROUTER_API_KEY=sk-or-your-key-here
OPENROUTER_MODEL=google/gemini-2.5-flash-lite

# Marketplaces — Mercado Livre
ML_AFFILIATE_ID=your-ml-affiliate-id
ML_SITE_ID=MLB
ML_TOOL_ID=your-ml-tool-id
ML_WORD_ID=your-ml-word-id

# Marketplaces — Amazon
AMAZON_AFFILIATE_TAG=your-tag-20

# Marketplaces — Shopee
SHOPEE_APP_ID=your-app-id
SHOPEE_SECRET=your-secret-here

# Timezone
TZ=America/Sao_Paulo
